projection;
strict ( 2 );
use draft;

define behavior for ZC_BpMapRecipient alias Recipient
{
  use create;
  use update;
  use delete;

  use action previewJson;

  use action Resume;
  use action Edit;
  use action Activate;
  use action Discard;
  use action Prepare;

  use association _FieldMapping { create; with draft; }
}

define behavior for ZC_BpMapField alias FieldMapping
{
  use update;
  use delete;

  use association _Recipient { with draft; }
}
